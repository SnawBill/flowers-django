SECRET_KEY=replace-with-a-long-random-value
DEBUG=0
DOMAIN=example.com
ALLOWED_HOSTS=example.com,www.example.com,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

POSTGRES_DB=flower_shop
POSTGRES_USER=flowers
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://flowers:replace-with-a-strong-password@db:5432/flower_shop

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_SIMULATION=1
YOOKASSA_TEST_MODE=1
YOOKASSA_RECEIPTS_ENABLED=0
YOOKASSA_VAT_CODE=1
PAYMENT_BASE_URL=https://example.com

SELLER_NAME=Фамилия Имя Отчество
SELLER_INN=000000000000
SELLER_PHONE=+7 900 000-00-00
SELLER_EMAIL=mail@example.com
SELLER_CITY=Город
DELIVERY_PRICE=500
DELIVERY_TIME=до 2 часов

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=mail@example.com
EMAIL_HOST_PASSWORD=replace-with-an-app-password
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=mail@example.com
CONTACT_EMAIL=mail@example.com

# Caddy автоматически выпускает сертификат для DOMAIN.
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=0
